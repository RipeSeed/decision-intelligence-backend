PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Google OAuth (Gmail readonly) ---
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Default to the highest-reasoning Claude model for the decision analysis.
# Override with claude-sonnet-4-6 for cheaper/faster runs.
CLAUDE_MODEL=claude-opus-4-7

# --- Email fetching ---
EMAIL_FETCH_HOURS=24
EMAIL_MAX_BODY_CHARS=4000
EMAIL_MAX_COUNT=50

# --- Local token cache (single-user prototype) ---
TOKENS_FILE=.tokens/tokens.json
